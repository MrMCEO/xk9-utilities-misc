# Токен бота от @BotFather
BOT_TOKEN=

# ID администраторов (через запятую)
ADMIN_IDS=123456789

# URL Web App
WEB_APP_URL=https://your-domain.com/app/v2/index.html

# Путь к базе данных SQLite
DB_PATH=casino.db

# Курс: 1 звезда Telegram = N игровых монет
COINS_PER_STAR=10

# HTTP порт сервера
PORT=8080

# Публичный URL сервера (для CORS и WebApp)
BOT_API_URL=http://localhost:8080
